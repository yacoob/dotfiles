**/*.src.ini

# guarded mode exclusions
{{ if .guardedMode -}}
.ssh/authorized_keys
.ssh/allowedSigners
.face.icon
{{- end }}

# git oauth helper
{{ if not (lookPath "git-credential-oauth") -}}
.gitconfig.oauth
{{- end }}

# zsh completions
{{ if not (lookPath "chezmoi_modify_manager") -}}
.zsh/completion/_chezmoi_modify_manager
{{- end }}

# lazyvim
{{ if not .install.lazyvim -}}
.config/nvim
{{- end }}

# mise installs
#
{{ if not .install.feishin -}}
.config/mise/conf.d/feishin.toml
{{- end }}

{{ if not .install.lm_studio -}}
.config/mise/conf.d/lm_studio.toml
{{- end }}

{{ if not .install.neovide -}}
.config/mise/conf.d/neovide.toml
{{- end }}

{{ if not .install.obsidian -}}
.config/mise/conf.d/obsidian.toml
{{- end }}
